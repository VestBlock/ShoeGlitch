# Copy to .env.local and fill in real values.
# Get these from Supabase → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
DATABASE_URL=postgresql://postgres:YOUR_DATABASE_PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Optional — for magic-link redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email / alerts
RESEND_API_KEY=
ADMIN_ALERT_EMAIL=
# Optional comma-separated override list for multiple admin recipients.
# ADMIN_ALERT_EMAILS=owner@shoeglitch.com,ops@shoeglitch.com

# Sneaker intelligence providers
# KICKS_API_KEY mirrors the current Vercel project name.
# KICKSDB_API_KEY is also supported for future cleanup.
KICKS_API_KEY=
KICKSDB_API_KEY=
KICKSDB_API_BASE_URL=https://api.kicks.dev/v3
KICKSDB_PLAN=free
# Optional release automation overrides
# KICKSDB_DAILY_REQUEST_BUDGET=20
# KICKSDB_NEW_RELEASE_PAGES_PER_DAY=4
# KICKSDB_WORTH_RESTORING_PAGES_PER_DAY=1
# KICKSDB_HOW_TO_CLEAN_PAGES_PER_DAY=2
# KICKSDB_RELEASE_ALERT_PAGES_PER_DAY=3
# KICKSDB_REFRESHES_PER_DAY=8

# Social automation
# Used only by internal social queue routes/scripts.
SOCIAL_CRON_SECRET=
# Either BUFFER_ACCESS_TOKEN or BUFFER_API_TOKEN works.
BUFFER_ACCESS_TOKEN=
BUFFER_API_TOKEN=
BUFFER_ORGANIZATION_ID=6824f713908a500d1955f4d4
# Pin the ShoeGlitch Instagram channel so Buffer does not pick another connected account.
BUFFER_INSTAGRAM_CHANNEL_ID=69e98be2031bfa423c32f496
# Optional social automation knobs
# SOCIAL_DRAFT_SCAN_LIMIT=8
# SOCIAL_PUBLISH_LIMIT=5

# PayPal (add when wiring payments)
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=
# PAYPAL_SECRET=
# PAYPAL_MODE=sandbox

# Shippo mail-in labels
SHIPPO_API_KEY=
# Optional: override the mail-in hub details used for prepaid inbound labels.
# If omitted, ShoeGlitch falls back to the active mail-in city's `hubAddress`.
# SHIPPO_MAILIN_HUB_NAME=Shoe Glitch Mail-In
# SHIPPO_MAILIN_HUB_EMAIL=contact@shoeglitch.com
# SHIPPO_MAILIN_HUB_PHONE=
# SHIPPO_MAILIN_HUB_LINE1=
# SHIPPO_MAILIN_HUB_LINE2=
# SHIPPO_MAILIN_HUB_CITY=
# SHIPPO_MAILIN_HUB_STATE=
# SHIPPO_MAILIN_HUB_ZIP=
