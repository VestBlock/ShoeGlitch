# Copy to .env.local and fill in real values.
# Get these from Supabase → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Optional — for magic-link redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sneaker intelligence providers
# KICKS_API_KEY mirrors the current Vercel project name.
# KICKSDB_API_KEY is also supported for future cleanup.
KICKS_API_KEY=
KICKSDB_API_KEY=
KICKSDB_API_BASE_URL=https://api.kicks.dev/v3

# PayPal (add when wiring payments)
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=
# PAYPAL_SECRET=
# PAYPAL_MODE=sandbox
